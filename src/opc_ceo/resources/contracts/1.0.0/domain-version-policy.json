{
  "classifications": {
    "evidence": {
      "mode": "immutable_successor",
      "required_fields": ["record_id", "stable_id", "revision", "supersedes"],
      "summary": "Business evidence must be superseded by a new immutable revision."
    },
    "p0_imported": {
      "mode": "external_authority",
      "required_fields": ["record_id"],
      "summary": "P0 imported records remain owned by the Google Sheets source until explicit ownership migration."
    },
    "working": {
      "mode": "revisioned_in_place",
      "required_fields": ["record_id", "revision"],
      "summary": "Working records may update in place only with a monotonically increasing revision."
    }
  },
  "record_types": {
    "contract": {
